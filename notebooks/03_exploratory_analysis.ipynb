   "source": [
    "# Step 3: Exploratory Data Analysis (EDA)\n",
    "\n",
    "## Objective\n",
    "Discover patterns, relationships, and insights in the cleaned hotel booking data through statistical analysis and visualizations.\n",
    "\n",
    "## Goals\n",
    "- Analyze booking patterns and seasonality\n",
    "- Study customer demographics\n",
    "- Examine cancellation rates\n",
    "- Analyze pricing and revenue metrics\n",
    "- Create meaningful visualizations\n",
    "- Identify key trends and anomalies"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.1 Import Libraries"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import sys\n",
    "sys.path.append('..')\n",
    "from src import data_processing, visualization, analysis\n",
    "\n",
    "sns.set_style('whitegrid')\n",
    "plt.rcParams['figure.figsize'] = (14, 6)\n",
    "%matplotlib inline"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.2 Load Cleaned Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load the cleaned dataset\n",
    "data_path = '../data/processed/hotel_bookings_cleaned.csv'\n",
    "df = data_processing.load_data(data_path)\n",
    "print(f\"Data loaded: {df.shape}\")\n",
    "print(f\"\\nColumns: {df.columns.tolist()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.3 Booking Summary Statistics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate booking summary\n",
    "summary = analysis.booking_summary(df)\n",
    "print(\"\\n=== BOOKING SUMMARY ===")\n",
    "for key, value in summary.items():\n",
    "    print(f\"{key}: {value}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.4 Cancellation Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Analyze cancellations\n",
    "cancellation_stats = analysis.cancellation_analysis(df)\n",
    "print(\"\\n=== CANCELLATION ANALYSIS ===")\n",
    "for key, value in cancellation_stats.items():\n",
    "    print(f\"{key}: {value}\")\n",
    "\n",
    "# Visualize cancellations\n",
    "visualization.plot_cancellation_distribution(df)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.5 Revenue Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Analyze revenue metrics\n",
    "revenue_stats = analysis.revenue_analysis(df)\n",
    "print(\"\\n=== REVENUE ANALYSIS ===")\n",
    "for key, value in revenue_stats.items():\n",
    "    print(f\"{key}: {value}\")\n",
    "\n",
    "# Visualize ADR distribution\n",
    "if 'adr' in df.columns:\n",
    "    visualization.plot_adr_distribution(df)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.6 Monthly Booking Trends"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Analyze monthly trends\n",
    "if 'arrival_date_month' in df.columns:\n",
    "    visualization.plot_monthly_trends(df)\n",
    "    \n",
    "    monthly_data = df.groupby('arrival_date_month').size()\n",
    "    print(\"\\nBookings by Month:\")\n",
    "    print(monthly_data)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.7 Customer Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Analyze customer types\n",
    "if 'customer_type' in df.columns:\n",
    "    visualization.plot_customer_type_distribution(df)\n",
    "    \n",
    "    customer_segments = analysis.customer_segmentation(df, 'customer_type')\n",
    "    print(\"\\nCustomer Type Distribution:\")\n",
    "    print(customer_segments)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.8 Lead Time Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Analyze lead times\n",
    "if 'lead_time' in df.columns:\n",
    "    visualization.plot_lead_time_analysis(df)\n",
    "    \n",
    "    print(f\"\\nLead Time Statistics:\")\n",
    "    print(f\"Mean: {df['lead_time'].mean():.1f} days\")\n",
    "    print(f\"Median: {df['lead_time'].median():.1f} days\")\n",
    "    print(f\"Min: {df['lead_time'].min()} days\")\n",
    "    print(f\"Max: {df['lead_time'].max()} days\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.9 Correlation Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Analyze correlations between numeric variables\n",
    "numeric_cols = df.select_dtypes(include=[np.number]).columns\n",
    "correlation_matrix = df[numeric_cols].corr()\n",
    "\n",
    "# Visualize correlations\n",
    "plt.figure(figsize=(12, 8))\n",
    "sns.heatmap(correlation_matrix, annot=True, fmt='.2f', cmap='coolwarm', center=0)\n",
    "plt.title('Correlation Matrix of Numeric Variables', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig('../results/figures/correlation_matrix.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"\\nCorrelation Matrix saved!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.10 Key Insights"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate key insights\n",
    "insights = analysis.get_insights(df)\n",
    "print(\"\\n=== KEY INSIGHTS ===")\n",
    "for i, insight in enumerate(insights, 1):\n",
    "    print(f\"{i}. {insight}\")"
   ]
  },
