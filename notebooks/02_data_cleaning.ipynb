   "source": [
    "# Step 2: Data Cleaning & Preparation\n",
    "\n",
    "## Objective\n",
    "Clean and prepare the data for analysis by handling missing values, removing duplicates, and creating new features.\n",
    "\n",
    "## Goals\n",
    "- Handle missing values appropriately\n",
    "- Remove duplicate records\n",
    "- Standardize column names and formats\n",
    "- Create new meaningful features\n",
    "- Ensure data consistency\n",
    "- Export cleaned dataset"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2.1 Import Libraries"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import sys\n",
    "sys.path.append('..')\n",
    "from src import data_processing\n",
    "\n",
    "pd.set_option('display.max_columns', None)\n",
    "%matplotlib inline"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2.2 Load Raw Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load the raw data\n",
    "data_path = '../data/raw/hotel_bookings.csv'\n",
    "df_raw = data_processing.load_data(data_path)\n",
    "print(f\"Original dataset shape: {df_raw.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2.3 Data Cleaning Pipeline"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Apply complete cleaning pipeline\n",
    "df_clean = data_processing.clean_data(df_raw.copy())\n",
    "print(f\"\\nCleaned dataset shape: {df_clean.shape}\")\n",
    "print(f\"Rows removed: {len(df_raw) - len(df_clean)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2.4 Standardize Column Names"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Verify column standardization\n",
    "print(\"Standardized Column Names:\")\n",
    "print(df_clean.columns.tolist())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2.5 Handle Data Type Conversions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Convert data types as needed\n",
    "# Example: convert date columns to datetime\n",
    "\n",
    "# Identify columns that should be datetime\n",
    "date_columns = [col for col in df_clean.columns if 'date' in col.lower()]\n",
    "print(f\"Date columns detected: {date_columns}\")\n",
    "\n",
    "# Convert if they exist\n",
    "for col in date_columns:\n",
    "    if col in df_clean.columns:\n",
    "        try:\n",
    "            df_clean[col] = pd.to_datetime(df_clean[col])\n",
    "            print(f\"✓ Converted {col} to datetime\")\n",
    "        except:\n",
    "            print(f\"✗ Could not convert {col}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2.6 Create New Features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create new features from existing data\n",
    "\n",
    "# Example: Create total_guests feature if adults and children columns exist\n",
    "if 'adults' in df_clean.columns and 'children' in df_clean.columns:\n",
    "    df_clean['total_guests'] = df_clean['adults'] + df_clean['children']\n",
    "    print(\"✓ Created total_guests feature\")\n",
    "\n",
    "# Example: Create total_stay feature\n",
    "if 'stays_in_weekend_nights' in df_clean.columns and 'stays_in_week_nights' in df_clean.columns:\n",
    "    df_clean['total_nights'] = df_clean['stays_in_weekend_nights'] + df_clean['stays_in_week_nights']\n",
    "    print(\"✓ Created total_nights feature\")\n",
    "\n",
    "# Display new features\n",
    "print(f\"\\nDataset shape after feature engineering: {df_clean.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2.7 Data Validation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Validate data after cleaning\n",
    "print(\"\\n=== DATA VALIDATION ===")\n",
    "print(f\"\\nTotal rows: {len(df_clean):,}\")\n",
    "print(f\"Total columns: {len(df_clean.columns)}\")\n",
    "print(f\"\\nRemaining missing values:\")\n",
    "print(df_clean.isnull().sum().sum())\n",
    "\n",
    "# Check data types\n",
    "print(f\"\\nData types:\")\n",
    "print(df_clean.dtypes)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2.8 Export Cleaned Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save the cleaned dataset\n",
    "output_path = '../data/processed/hotel_bookings_cleaned.csv'\n",
    "data_processing.export_data(df_clean, output_path)\n",
    "print(f\"✓ Cleaned data exported to {output_path}\")"
   ]
  },
